NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=hospital_registration
MYSQL_USER=hospital_app
MYSQL_PASSWORD=change-me
MYSQL_CONNECTION_LIMIT=10

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d

# 32-byte key encoded as base64. Generate with: openssl rand -base64 32
DATA_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Development-only SMS verification code. Ignored in production.
DEV_SMS_CODE=123456
